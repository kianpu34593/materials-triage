# Copy to .env and fill in. Never commit the real .env (it is gitignored).

# --- Materials Project (the public numeric source) — REQUIRED ---
# API key for the sandboxed Materials Project mirror.
X_API_KEY=

# --- AWS Bedrock (the LLM backend) — REQUIRED for live runs ---
# Static keys are simplest inside a container. Alternatively use AWS_PROFILE
# with a mounted ~/.aws, or SSO.
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_REGION=us-east-1

# --- OpenAlex literature search — OPTIONAL ---
# An email enables OpenAlex's faster "polite pool"; search works without it.
OPENALEX_MAILTO=
