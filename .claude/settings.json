{
  "enabledPlugins": {
    "commit-commands@claude-plugins-official": true
  },
  "permissions": {
    "allow": [
      "Read",
      "Bash(ls:*)",
      "Bash(cat:*)",
      "Bash(grep:*)",
      "Bash(rg:*)",
      "Bash(find:*)",
      "Bash(git status)",
      "Bash(git diff:*)",
      "Bash(git log:*)",
      "Bash(python -m pytest:*)",
      "Bash(python -c:*)",
      "Bash(pip list)",
      "Bash(conda list)",
      "Bash(pytest:*)"
    ],
    "ask": [
      "Bash(git commit:*)",
      "Bash(git push:*)",
      "Bash(pip install:*)",
      "Bash(conda install:*)",
      "Bash(psql:*)",
      "Bash(dropdb:*)"
    ],
    "deny": [
      "Bash(rm -rf:*)",
      "Bash(git push --force:*)",
      "Bash(git reset --hard:*)",
      "Bash(sudo:*)",
      "Bash(curl* | bash)",
      "Bash(curl* | sh)",
      "Read(.env)",
      "Read(.env.*)",
      "Read(**/*secret*)",
      "Read(**/.aws/**)",
      "Read(**/.ssh/**)"
    ]
  }
}
