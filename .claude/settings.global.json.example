{
  "permissions": {
    "deny": [
      "Bash(rm -rf:*)",
      "Bash(git push --force:*)",
      "Bash(git reset --hard:*)",
      "Bash(sudo:*)",
      "Bash(curl* | bash)",
      "Bash(curl* | sh)",
      "Read(.env)",
      "Read(.env.*)",
      "Read(**/*secret*)",
      "Read(**/.aws/**)",
      "Read(**/.ssh/**)"
    ]
  },
  "model": "opus[1m]",
  "enabledPlugins": {
    "mcp-server-dev@claude-plugins-official": true
  },
  "effortLevel": "medium",
  "awaySummaryEnabled": false,
  "skipDangerousModePermissionPrompt": true,
  "autoCompactEnabled": true,
  "statusLine": {
    "type": "command",
    "command": "bash ~/.claude/statusline-command.sh"
  }
}
